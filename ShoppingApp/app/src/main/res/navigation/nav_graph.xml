    android:id="@+id/nav_graph"
    app:startDestination="@id/nav_lista">

    <fragment
        android:id="@+id/nav_lista"
        android:name="com.javito.shoplist.ui.shopping.ShoppingListFragment"
        android:label="@string/nav_lista"
        tools:layout="@layout/fragment_shopping_list" />

    <fragment
        android:id="@+id/nav_facturas"
