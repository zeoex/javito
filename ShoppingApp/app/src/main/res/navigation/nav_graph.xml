    <fragment
        android:id="@+id/nav_resumen"
        android:name="com.javito.shoplist.ui.resumen.ResumenFragment"
        android:label="@string/nav_resumen"
        tools:layout="@layout/fragment_resumen" />

    <fragment
        android:id="@+id/nav_estadisticas"
